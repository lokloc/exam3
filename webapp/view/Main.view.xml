<mvc:View controllerName="code.d01.exam3.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <Panel 
                headerText="{i18n>staffList}"
                height="600px"
                class="sapUiResponsiveMargin"
                width="auto"
                >
        
            <Table 
                items="{/Employees}"
                mode="SingleSelectMaster"
                selectionChange="onSelectChange"
                >
                <columns>
                    <Column ><header><Text text="{i18n>staffID}"></Text></header></Column>
                    <Column ><header><Text text="{i18n>staffNickName}"></Text></header></Column>
                    <Column ><header><Text text="{i18n>staffName}"></Text></header></Column>
                    <Column ><header><Text text="{i18n>staffLVL}"></Text></header></Column>
                    <Column ><header><Text text="{i18n>staffWD}"></Text></header></Column>
                    <Column ><header><Text text="{i18n>staffCon}"></Text></header></Column>
                </columns>
                <items>
                    <ColumnListItem 
                            type="Navigation"
                    >
                        <ObjectIdentifier text="{EmployeeID}"></ObjectIdentifier>
                        <Text text="{LastName}"></Text>
                        <Text text="{FirstName}"></Text>
                        <Text text="{Title}"></Text>
                        <Text text="{
                            path: 'HireDate',
                            type: 'sap.ui.model.type.Date',
                            formatOptions: {
                                    pattern: 'yyyy-MM-dd'
                            }
                        }"></Text>
                        <Text text="{Country}"></Text>
                    </ColumnListItem>
                </items>





            
            </Table>

        
        
        </Panel>
    </Page>
</mvc:View>